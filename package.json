{
  "name": "@cocorof/graphier",
  "version": "1.3.2",
  "description": "High-performance 3D/2D graph renderer for React — powered by Three.js and d3-force-3d",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./analysis": {
      "types": "./dist/analysis.d.ts",
      "import": "./dist/analysis.js",
      "require": "./dist/analysis.cjs",
      "default": "./dist/analysis.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:fast": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.150.0"
  },
  "dependencies": {
    "d3-force-3d": "^3.0.6"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.170.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0"
  },
  "keywords": [
    "graph",
    "network",
    "3d",
    "2d",
    "visualization",
    "three.js",
    "react",
    "force-directed",
    "node",
    "edge",
    "renderer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CocoRoF/graphier.git"
  },
  "homepage": "https://github.com/CocoRoF/graphier#readme",
  "bugs": {
    "url": "https://github.com/CocoRoF/graphier/issues"
  },
  "author": "CocoRoF"
}
